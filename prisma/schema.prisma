generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String @id @default(uuid())
  name       String
  email      String @unique
  password   String
  role       Role
  department Department?
}

model Patient {
  id        String   @id @default(uuid())
  name      String
  age       Int
  gender    String
  phone     String
  visits    Visit[]
  createdAt DateTime @default(now())
}
enum VisitStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
}

model Visit {
  id           String      @id @default(uuid())
  patientId    String
  department   Department
  transcript   String?
  language     String?       // "en-IN" | "kn-IN" | "hi-IN"
  audioUrl     String?
  messages     Json?         // full conversation turns array

  // ── NEW ──
  status       VisitStatus  @default(WAITING)
  reports      Json?         // Json array of MedicalReport objects (one per session)
  completedAt  DateTime?     // set when doctor clicks Complete

  // keep legacy single-report field for backward compat
  report       Json?

  createdAt    DateTime     @default(now())
  patient      Patient      @relation(fields: [patientId], references: [id])
}


enum Role {
  DOCTOR
  RECEPTION
}

enum Department {
  GENERAL_MEDICINE
  PEDIATRICS
  GYNECOLOGY
  ORTHOPEDICS
  ENT
}